# Build frontend
FROM node:24 AS builder-front
WORKDIR /front
RUN corepack enable
COPY front/package.json front/pnpm-lock.yaml front/pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile
COPY front/ ./
ARG APP_VERSION=dev
ENV VITE_APP_VERSION=$APP_VERSION
RUN pnpm run build

# Build backend
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS builder-back
WORKDIR /src
COPY global.json ./
COPY back/ ./back/
RUN dotnet restore back/ProxmoxIpMonitor.Web/ProxmoxIpMonitor.Web.csproj
RUN dotnet publish back/ProxmoxIpMonitor.Web/ProxmoxIpMonitor.Web.csproj -c Release -o /app/publish --no-restore

# Runtime
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS production
ENV TZ=Europe/Paris
ENV ASPNETCORE_URLS=http://+:4000
ENV ASPNETCORE_ENVIRONMENT=Production
WORKDIR /app
COPY --from=builder-back /app/publish ./
COPY --from=builder-front /front/dist ./wwwroot
EXPOSE 4000
ENTRYPOINT ["dotnet", "ProxmoxIpMonitor.Web.dll"]
