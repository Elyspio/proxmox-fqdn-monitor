{
  "realm": "proxmox-ip-monitor",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "proxmox-ip-monitor-admin",
        "description": "Full access. Mirrors the realm role expected in the internal realm."
      }
    ]
  },
  "clients": [
    {
      "clientId": "proxmox-ip-monitor",
      "name": "Proxmox IP Monitor (SPA)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      },
      "protocolMappers": [
        {
          "name": "audience-proxmox-ip-monitor",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "proxmox-ip-monitor",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@local",
      "firstName": "admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "proxmox-ip-monitor-admin"
      ]
    },
    {
      "username": "user",
      "enabled": true,
      "emailVerified": true,
      "email": "user@local",
      "firstName": "No",
      "lastName": "Roles",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ]
    }
  ]
}
