{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "OpenTelemetry": {
    "Service": "proxmox-ip-monitor",
    "CollectorUri": "http://localhost:4318/",
    "Protocol": "HttpProtobuf",
    "Capture": {
      "Activated": true
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MongoDB": "mongodb://localhost:27017/proxmox-ip-monitor"
  },
  "Auth": {
    "Authority": "",
    "Audience": "proxmox-ip-monitor",
    "AdminRole": "proxmox-ip-monitor-admin"
  },
  "DataProtection": {
    "MasterKey": ""
  },
  "Cors": {
    "AllowedOrigins": []
  }
}
